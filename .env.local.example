# MongoDB Atlas connection string (database name: african_stores)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority

# Public site URL (local dev or production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry (https://quephase-gm.sentry.io/projects/javascript-nextjs/)
# Client + server DSN from Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
# Auth token for source map uploads (CI / Vercel). Keep secret.
# Create at https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=
